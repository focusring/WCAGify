# Admin secret — required for production deployments
# Protects report access and share link management
# WCAGIFY_ADMIN_SECRET=your-secret-here

# Remote database (optional) — for serverless platforms without persistent disk
# Supports any LibSQL-compatible URL (Turso, self-hosted libsql-server, etc.)
# When not set, WCAGify uses a local SQLite file at .data/shares.sqlite
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token
