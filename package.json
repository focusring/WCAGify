{
  "name": "@wcagify/monorepo",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @wcagify/playground dev",
    "build": "pnpm --filter @wcagify/playground build",
    "preview": "pnpm --filter @wcagify/playground preview",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "pnpm --filter @wcagify/playground typecheck",
    "docs:dev": "pnpm --filter @wcagify/docs dev",
    "docs:build": "pnpm --filter @wcagify/docs build",
    "release": "bumpp package.json packages/*/package.json docs/package.json --all -x \"npx changelogen --no-output\""
  },
  "devDependencies": {
    "bumpp": "^10.4.1",
    "changelogen": "^0.6.2",
    "changelogithub": "^14.0.0",
    "oxfmt": "^0.34.0",
    "oxlint": "^1.49.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
